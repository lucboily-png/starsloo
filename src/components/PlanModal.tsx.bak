'use client'

import { useState } from 'react'
import { loadStripe } from '@stripe/stripe-js'

type Plan = {
  nameFR: string
  nameEN: string
  color: string
  sms: string
  priceText: string
  priceId: string
  advantages: {
    FR: string[]
    EN: string[]
  }
  modalContent?: {
    FR: string
    EN: string
  }
}

type PlanModalProps = {
  open: boolean
  businessId: string
  onClose: () => void
  lang: "FR" | "EN"
}

const plans: Plan[] = [
  {
    nameFR: "Je veux l’essayer 🎯",
    nameEN: "Starter 🎯",
    sms: "90 SMS",
    priceText: "$19.99",
    priceId: "price_1T5e6CEyGK0Xf3bphUQDpxig",
    color: "#1e293b",
    advantages: {
      FR: [
        "Collecte d’avis Google simplifiée",
        "Automatisation SMS",
        "Dashboard inclus",
        "Support email"
      ],
      EN: [
        "Easy Google review collection",
        "SMS automation",
        "Dashboard access",
        "Email support"
      ]
    },
    modalContent: {
      FR: "Idéal pour commencer et tester la puissance de Starsloo.",
      EN: "Perfect to start and test the power of Starsloo."
    }
  },
  {
    nameFR: "WOW 🔥",
    nameEN: "Growth 🔥",
    sms: "250 SMS",
    priceText: "$29.99",
    priceId: "price_1T5e7KEyGK0Xf3bpV6yhZEvK",
    color: "#1e293b",
    advantages: {
      FR: [
        "Augmentez vos avis rapidement",
        "Plus de volume SMS",
        "Statistiques avancées",
        "Support prioritaire"
      ],
      EN: [
        "Boost reviews faster",
        "Higher SMS volume",
        "Advanced analytics",
        "Priority support"
      ]
    },
    modalContent: {
      FR: "Le plan préféré des entreprises en croissance.",
      EN: "Most popular plan for growing businesses."
    }
  },
  {
    nameFR: "Incroyable 🚀",
    nameEN: "Pro 🚀",
    sms: "600 SMS",
    priceText: "$49.99",
    priceId: "price_1T5e9REyGK0Xf3bpasnTX12f",
    color: "#111827",
    advantages: {
      FR: [
        "Volume SMS élevé",
        "Analytics complètes",
        "Optimisation maximale des avis",
        "Support ultra-prioritaire"
      ],
      EN: [
        "High SMS volume",
        "Full analytics",
        "Maximum review optimization",
        "Ultra priority support"
      ]
    },
    modalContent: {
      FR: "Pour les entreprises ambitieuses qui veulent dominer.",
      EN: "For ambitious businesses ready to dominate."
    }
  }
]

export default function PlanModal({ open, businessId, onClose, lang }: PlanModalProps) {
  const [loading, setLoading] = useState(false)

  if (!open) return null

  const handlePlanClick = async (plan: Plan) => {
    try {
      setLoading(true)
      const res = await fetch('/api/create-checkout-session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          priceId: plan.priceId,
          businessId,
          planName: lang === "FR" ? plan.nameFR : plan.nameEN,
          smsMax: parseInt(plan.sms.replace(/\D/g, ''))
        }),
      })

      const data = await res.json()
      if (!res.ok) throw new Error(data.error || 'Stripe error')

      window.location.href = data.url
    } catch (err: any) {
      alert(err.message)
      setLoading(false)
    }
  }

  return (
    <div style={{
      position:'fixed',
      inset:0,
      background:'rgba(0,0,0,0.6)',
      display:'flex',
      justifyContent:'center',
      alignItems:'center',
      zIndex:1000
    }}>
      <div style={{
        background:'#f8fafc',
        padding:'40px',
        borderRadius:'20px',
        width:'95%',
        maxWidth:'1100px'
      }}>
        <h2 style={{
          textAlign:'center',
          marginBottom:'40px',
          fontSize:'28px'
        }}>
          {lang === "FR" ? "Choisissez votre plan" : "Choose your plan"}
        </h2>

        <div style={{
          display:'flex',
          gap:'30px',
          justifyContent:'center',
          flexWrap:'wrap'
        }}>
          {plans.map((plan, index) => (
            <div
              key={plan.priceId}
              style={{
                background: plan.color,
                color:'#fff',
                borderRadius:'18px',
                padding:'30px',
                width:'280px',
                boxShadow:'0 15px 30px rgba(0,0,0,0.2)',
                transform: index === 1 ? 'scale(1.05)' : 'scale(1)',
                transition:'0.3s'
              }}
            >
              <u><h3 style={{  fontSize:'20px', marginBottom:'10px' }}>
                {lang === "FR" ? plan.nameFR : plan.nameEN}
              </h3></u>

              <p style={{
				 
                fontSize:'20px',
                opacity:0.8,
                marginBottom:'20px',
                minHeight:'50px'
              }}>
                {lang === "FR"
                  ? plan.modalContent?.FR
                  : plan.modalContent?.EN}
              </p>

              <ul style={{
                fontSize:'13px',
                paddingLeft:'18px',
                marginBottom:'25px',
                lineHeight:'1.6'
              }}>
                {(lang === "FR"
                  ? plan.advantages.FR
                  : plan.advantages.EN).map((adv, i) => (
                  <li key={i}>{adv}</li>
                ))}
              </ul>

              <button
                onClick={() => handlePlanClick(plan)}
                disabled={loading}
                style={{
                  width:'100%',
                  padding:'12px',
                  borderRadius:'10px',
                  border:'none',
                  background:'#22c55e',
                  color:'#fff',
                  fontWeight:700,
                  fontSize:'15px',
                  cursor:'pointer',
                  marginBottom:'15px'
                }}
              >
                {loading
                  ? (lang === "FR" ? "Chargement..." : "Loading...")
                  : (lang === "FR" ? "Choisir" : "Select")}
              </button>

              {/* PRIX + SMS EN BAS */}
              <div style={{ textAlign:'center' }}>
                <div style={{ fontSize:'24px', fontWeight:800 }}>
                  {plan.priceText}
                  <span style={{ fontSize:'12px', opacity:0.7 }}> /mo</span>
                </div>
                <div style={{ fontSize:'13px', opacity:0.8 }}>
                  {plan.sms}
                </div>
              </div>
            </div>
          ))}
        </div>

        <div style={{ textAlign:'center', marginTop:'40px' }}>
          <button
            onClick={onClose}
            style={{
              padding:'10px 25px',
              borderRadius:'10px',
              border:'none',
              background:'#1f2937',
              color:'#fff',
              cursor:'pointer'
            }}
          >
            {lang === "FR" ? "Fermer" : "Close"}
          </button>
        </div>
      </div>
    </div>
  )
}