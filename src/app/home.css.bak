/* Reset & basics */
* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
body { background: #f4f6fc; color: #111827; }

/* Container */
.home-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 3rem 2rem;
  background: linear-gradient(135deg, #e0ebff, #f4f6fc);
}

/* Header */
.home-header {
  text-align: center;
  margin-bottom: 3rem;
}
.home-title {
  font-size: 3rem;
  font-weight: 800;
  color: #1e3a8a;
  margin-bottom: 0.5rem;
}
.home-subtitle {
  font-size: 1.2rem;
  color: #374151;
}

/* Hero Section */
.hero {
  text-align: center;
  padding: 4rem 2rem;
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  border-radius: 25px;
  color: white;
  margin-bottom: 3rem;
  box-shadow: 0 15px 35px rgba(0,0,0,0.1);
}
.hero-title {
  font-size: 2.8rem;
  font-weight: 900;
  margin-bottom: 1rem;
}
.hero-subtitle {
  font-size: 1.3rem;
  margin-bottom: 2rem;
  line-height: 1.5;
  max-width: 700px;
  margin-left: auto;
  margin-right: auto;
  color: #e0e7ff;
}
.hero-btn {
  font-size: 1.2rem;
  padding: 0.8rem 2.5rem;
  border-radius: 15px;
}
.hero-btn:hover {
  background: #2563eb;
  box-shadow: 0 8px 25px rgba(37,99,235,0.4);
}


/* Actions */
.home-actions {
  margin-bottom: 2.5rem;
}
.home-btn {
  padding: 0.8rem 2rem;
  font-size: 1.1rem;
  border-radius: 12px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s;
}
.btn-primary {
  background: #F5AD27;
  color: white;
  border: none;
}

/* Hero Stars */
.hero-stars {
  display: flex;
  justify-content: center;
  gap: 0.4rem;
  margin-bottom: 1rem;
}
.hero-stars span {
  font-size: 2rem;
  color: gold;
  text-shadow: 0 2px 5px rgba(0,0,0,0.3);
}

.btn-primary:hover {
  background: #2563eb;
  box-shadow: 0 5px 15px rgba(37,99,235,0.3);
}
.btn-link {
  background: transparent;
  border: none;
  color: #1d4ed8;
  margin-top: 1rem;
  cursor: pointer;
  font-size: 0.9rem;
  text-decoration: underline;
}
.btn-link:hover {
  color: #2563eb;
}

/* Login Card */
.login-card {
  background: #D0EFF7;
  padding: 2.5rem 2rem;
  border-radius: 20px;
  box-shadow: 0 15px 30px rgba(0,0,0,0.08);
  width: 100%;
  max-width: 600px;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.login-title {
  font-size: 1.8rem;
  font-weight: 700;
  color: #1e3a8a;
  margin-bottom: 1rem;
}
.input {
  padding: 0.75rem 1rem;
  border-radius: 12px;
  border: 1px solid #d1d5db;
  font-size: 1rem;
  transition: all 0.2s;
}
.input:focus {
  outline: none;
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37,99,235,0.2);
}

/* Footer */
.home-footer {
  margin-top: 3rem;
  text-align: center;
  font-size: 0.9rem;
  color: #6b7280;
}

/* Responsive */
@media(max-width: 600px){
  .home-title { font-size: 2.2rem; }
  .login-card { padding: 2rem 1.5rem; }
  .home-btn { width: 100%; }
}

/* MARKETING SECTIONS STYLE HERO */
.marketing-hero-sections {
  display: flex;
  flex-direction: column;
  padding: 2.0rem 0rem;
  gap: 2rem;
  width: 90%;
  max-width: 1000px;
  margin: 1rem auto 0 auto;
  text-align: center;
}


.marketing-card {
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  color: white;
  border-radius: 25px;
  padding: 3rem 2rem;
  box-shadow: 0 15px 35px rgba(0,0,0,0.1);
  transition: transform 0.3s, box-shadow 0.3s;
}

.marketing-hero-sections2 {
  display: flex;
  flex-direction: column;
  padding: 2.0rem 0rem;
  gap: 2rem;
  width: 90%;
  max-width: 1000px;
  margin: 1rem auto 0 auto;
  text-align: center;
}

.marketing-card2 {
  background: ##8114e0;
  font-size: 20px;
  color: white;
  border-radius: 25px;
  padding: 3rem 2rem;
  box-shadow: 0 15px 35px rgba(0,0,0,0.1);
  transition: transform 0.3s, box-shadow 0.3s;
}

.marketing-card2 h2 {
  font-size: 2rem;
  font-weight: 900;
  margin-bottom: 2rem;
}

.marketing-card h3 {
  font-size: 2rem;
  font-weight: 900;
  margin-bottom: 1rem;
}

.marketing-card p {
  font-size: 1.2rem;
  line-height: 1.5;
  max-width: 700px;
  margin: 0 auto;
  color: #e0e7ff;
}

.marketing-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 18px 35px rgba(0,0,0,0.15);
}

/* GRID POUR GRAND ÉCRAN */
@media(min-width: 768px){
  .marketing-hero-sections {
    flex-direction: row;
    justify-content: space-between;
  }

  .marketing-card {
    flex: 1;
    margin: 0 10px;
  }
}
/* GRID LAYOUT FOR BIG SCREENS */
@media(min-width: 768px){
  .marketing-sections {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: left;
  }

  .marketing-card {
    text-align: center;
  }
}

/* ADD SOME SPACING BETWEEN LOGIN AND MARKETING */
.login-card {
  margin-bottom: 3rem;
}