body {
  background-color: #e6f0ff; /* bleu pâle */
  margin: 0;
  font-family: 'Inter', sans-serif;
}

html, body, #__next {
  height: 100%;
}

/* MARKETING SECTIONS STYLE HERO */
.marketing-hero-sectionsreg {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  width: 0, auto;
  max-width: 900px;
  margin: 3rem auto 0 auto;
  text-align: center;
}

.marketing-cardreg {
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  width: auto;
  color: white;
  border-radius: 25px;
  padding: 3rem 3rem;
  box-shadow: 0 15px 35px rgba(0,0,0,0.1);
  transition: transform 0.3s, box-shadow 0.3s;
}

.marketing-card h3 {
  font-size: 2rem;
  font-weight: 900;
  margin-bottom: 1rem;
}

.marketing-card p {
  font-size: 1.2rem;
  line-height: 1.5;
  max-width: 700px;
  margin: 0 auto;
  color: #e0e7ff;
}

.marketing-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 18px 35px rgba(0,0,0,0.15);
}

/* GRID POUR GRAND ÉCRAN */
@media(min-width: 768px){
  .marketing-hero-sections {
    flex-direction: row;
    justify-content: space-between;
  }

  .marketing-card {
    flex: 1;
    margin: 0 10px;
  }
}

/* Hero Stars */
.hero-stars {
  display: flex;
  justify-content: center;
  gap: 0.4rem;
  margin-bottom: 1rem;
}
.hero-stars span {
  font-size: 2rem;
  color: gold;
  text-shadow: 0 2px 5px rgba(0,0,0,0.3);
}

.btn-primary:hover {
  background: #2563eb;
  box-shadow: 0 5px 15px rgba(37,99,235,0.3);
}
.btn-link {
  background: transparent;
  border: none;
  color: #1d4ed8;
  margin-top: 1rem;
  cursor: pointer;
  font-size: 0.9rem;
  text-decoration: underline;
}
.btn-link:hover {
  color: #2563eb;
}

/* Login Card */
.login-card {
  background: #ffffff;
  padding: 2.5rem 2rem;
  border-radius: 20px;
  box-shadow: 0 15px 30px rgba(0,0,0,0.08);
  width: 100%;
  max-width: 400px;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* Footer */
.home-footer {
  margin-top: 3rem;
  text-align: center;
  font-size: 0.9rem;
  color: #6b7280;
}

